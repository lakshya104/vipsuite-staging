{
  "name": "vipsuit-frontend",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "preinstall": "node -e \"const ua = process.env.npm_config_user_agent; if (ua && ua.startsWith('npm')) { console.error('npm install is disabled for this repo. Use yarn only.'); process.exit(1); }\"",
    "dev": "next dev",
    "generate:assetlinks": "node scripts/generateAssetlinks.js && node scripts/generateAppleAppSiteAssociation.js",
    "generate:robotstxt": "node scripts/generateRobots.js",
    "build": "yarn generate:assetlinks && yarn generate:robotstxt && next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint-staged": "lint-staged",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=24.16.0",
    "yarn": ">=4.16.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^3.10.0",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@mui/material-nextjs": "^9.0.1",
    "@mui/system": "^6.5.0",
    "@mui/x-date-pickers": "^7.29.4",
    "@next/third-parties": "^16.2.6",
    "axios": "^1.7.9",
    "dayjs": "^1.11.12",
    "dotenv": "^16.4.7",
    "he": "^1.2.0",
    "jquery": "^4.0.0",
    "lodash": "^4.17.21",
    "next": "^16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "next-nprogress-bar": "^2.4.3",
    "persist-and-sync": "^1.2.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "react-signature-canvas": "^1.0.6",
    "react-slick": "^0.30.2",
    "sass": "^1.77.8",
    "slick-carousel": "^1.8.1",
    "use-debounce": "^10.0.3",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/he": "^1.2.3",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/react-slick": "^0.23.13",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.7.0",
    "eslint-config-next": "^16.2.7",
    "husky": "^9.1.7",
    "lint-staged": "^14.0.0",
    "prettier": "^3.3.3",
    "typescript": "5.6.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --ext .js,.jsx,.ts,.tsx",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "resolutions": {
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3"
  },
  "packageManager": "yarn@4.16.0"
}
